{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SpicyVPN",
  "version": "1.0.0",
  "identifier": "app.spicypepper.spicyvpn",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "SpicyVPN",
        "width": 380,
        "height": 580,
        "resizable": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "resources": ["binaries/*"],
    "externalBin": ["binaries/xray"]
  },
  "plugins": {
    "shell": {
      "open": true,
      "sidecar": true
    },
    "store": {}
  }
}
